// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_user
  project_admin
  admin
  manager
  user
  client
}

enum IRPriority {
  critical
  non_critical
}

enum IRStatus {
  draft
  awaiting_request_validation
  awaiting_response
  awaiting_response_validation
  awaiting_response_acceptance
  awaiting_closeout
  ir_recycle
  closed
}

model Company {
  id                String             @id @default(uuid())
  name              String
  code              String             @unique
  type              String             // contractor, client
  users             User[]
  requestsAsReq     InterfaceRequest[] @relation("RequestorCompany")
  requestsAsRes     InterfaceRequest[] @relation("ResponderCompany")
  projects          Project[]          @relation("ProjectCompanies")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Project {
  id               String             @id @default(uuid())
  name             String
  code             String             @unique
  isActive         Boolean            @default(true)
  companies        Company[]          @relation("ProjectCompanies")
  users            User[]             @relation("ProjectUsers")
  interfaceRequests InterfaceRequest[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model User {
  id              String             @id @default(uuid())
  name            String
  email           String             @unique
  role            UserRole           @default(user)
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])
  projects        Project[]          @relation("ProjectUsers")
  isActive        Boolean            @default(true)
  avatarInitials  String?
  requestsCreated InterfaceRequest[] @relation("RequestorUser")
  requestsToRes   InterfaceRequest[] @relation("ResponderUser")
  requestsAssigned InterfaceRequest[] @relation("AssignedUser")
  workflowLogs    WorkflowLog[]
  sentMessages    Message[]          @relation("SentMessages")
  receivedMessages Message[]         @relation("ReceivedMessages")
  notifications   Notification[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model InterfaceRequest {
  id                 String        @id @default(uuid())
  irNumber           String        @unique
  title              String
  description        String
  priority           IRPriority    @default(non_critical)
  status             IRStatus      @default(draft)
  projectId          String
  project            Project       @relation(fields: [projectId], references: [id])
  requestorCompanyId String
  requestorCompany   Company       @relation("RequestorCompany", fields: [requestorCompanyId], references: [id])
  responderCompanyId String
  responderCompany   Company       @relation("ResponderCompany", fields: [responderCompanyId], references: [id])
  requestorUserId    String
  requestorUser      User          @relation("RequestorUser", fields: [requestorUserId], references: [id])
  responderUserId    String?
  responderUser      User?         @relation("ResponderUser", fields: [responderUserId], references: [id])
  assignedUserId     String?
  assignedUser       User?         @relation("AssignedUser", fields: [assignedUserId], references: [id])
  dueDate            DateTime
  responseId         String?       @unique
  response           IRResponse?   @relation(fields: [responseId], references: [id])
  workflowLogs       WorkflowLog[]
  attachments        Attachment[]  @relation("RequestAttachments")
  closeOutDate       DateTime?
  closeOutComment    String?
  revision           Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model IRResponse {
  id               String            @id @default(uuid())
  content          String
  submittedAt      DateTime          @default(now())
  interfaceRequest InterfaceRequest?
  attachments      Attachment[]      @relation("ResponseAttachments")
}

model WorkflowLog {
  id         String           @id @default(uuid())
  requestId  String
  request    InterfaceRequest @relation(fields: [requestId], references: [id])
  step       String
  action     String
  actorId    String
  actor      User             @relation(fields: [actorId], references: [id])
  actorName  String
  comment    String?
  timestamp  DateTime         @default(now())
}

model Attachment {
  id         String            @id @default(uuid())
  filename   String
  size       Int
  url        String
  uploadedBy String
  uploadedAt DateTime          @default(now())
  requestId  String?
  request    InterfaceRequest? @relation("RequestAttachments", fields: [requestId], references: [id])
  responseId String?
  response   IRResponse?       @relation("ResponseAttachments", fields: [responseId], references: [id])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content    String
  timestamp  DateTime @default(now())
  isRead     Boolean  @default(false)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   // info, alert, success
  link      String?
  isRead    Boolean  @default(false)
  timestamp DateTime @default(now())
}
